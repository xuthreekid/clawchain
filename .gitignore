# ============================================================
# ClawChain .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
.eggs/
*.so
.venv/
venv/
env/

# Backend runtime data (all generated by `python cli.py setup`)
# Note: .gitkeep files are kept to ensure directory structure is tracked
backend/data/agents/
!backend/data/agents/.gitkeep
backend/data/subagents/
!backend/data/subagents/.gitkeep
backend/data/cron/
!backend/data/cron/.gitkeep
backend/data/config.json
backend/data/**/logs/
backend/data/**/*.jsonl

# Env files with secrets
backend/.env
!backend/.env.example

# Frontend
frontend/node_modules/
frontend/.next/
frontend/out/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test/cache
.pytest_cache/
backend/.pytest_cache/
**/.pytest_cache/
